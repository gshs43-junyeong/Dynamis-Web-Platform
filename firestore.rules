rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. notices
    match /notices/{noticeId} {
      allow read: if true;

      allow create: if request.auth != null
                    && isValidNotice(request.resource.data)
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.authorRole in ['general', 'member', 'honored', 'admin'];

      allow update: if request.auth != null
                    && (
                      (resource.data.authorId == request.auth.uid
                       && isValidNotice(request.resource.data)
                       && request.resource.data.authorId == resource.data.authorId
                       && request.resource.data.authorName == resource.data.authorName
                       && request.resource.data.authorRole == resource.data.authorRole
                       && request.resource.data.authorId == request.auth.uid)
                      || isAdmin()
                    );

      allow delete: if request.auth != null
                    && (resource.data.authorId == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
                      && isValidComment(request.resource.data)
                      && request.resource.data.authorId == request.auth.uid
                      && request.resource.data.authorRole in ['general', 'member', 'honored', 'admin'];
        allow update, delete: if request.auth != null
                              && (resource.data.authorId == request.auth.uid || isAdmin());
      }

      // 한 계정당 하트 1회, 취소 불가 (docId == 누른 사람 uid)
      match /likes/{likeId} {
        allow read: if true;
        allow create: if request.auth != null
                      && likeId == request.auth.uid
                      && isValidLike(request.resource.data, request.auth.uid);
        allow update, delete: if false;
      }
    }

    // 2. events (notice와 동일한 구조 + 마감 타이머)
    //    - 목록 카드(events/{eventId})는 항상 읽기 가능 (제목/작성자/마감시각)
    //    - 본문(events/{eventId}/content/main)은 마감 전에만 서버가 열어줌
    match /events/{eventId} {
      allow read: if true;

      allow create: if request.auth != null
                    && isValidEvent(request.resource.data)
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.authorRole in ['general', 'member', 'honored', 'admin'];

      allow update: if request.auth != null
                    && (
                      (resource.data.authorId == request.auth.uid
                       && isValidEvent(request.resource.data)
                       && request.resource.data.authorId == resource.data.authorId
                       && request.resource.data.authorName == resource.data.authorName
                       && request.resource.data.authorRole == resource.data.authorRole)
                      || isAdmin()
                    );

      allow delete: if request.auth != null
                    && (resource.data.authorId == request.auth.uid || isAdmin());

      // 본문: 마감 시각(부모 문서의 deadline) 이전에만 읽기 허용.
      // 서버 시계(request.time)로 판정하므로 클라이언트 시계 조작으로 우회 불가.
      // 작성자 본인과 관리자는 마감 후에도 관리 목적으로 열람 가능.
      match /content/{contentId} {
        allow read: if request.time.toMillis() < eventDeadline(database, eventId)
                    || isAdmin()
                    || (request.auth != null && eventAuthorId(database, eventId) == request.auth.uid);
        allow create, update: if request.auth != null
                    && isValidEventContent(request.resource.data)
                    && (eventAuthorId(database, eventId) == request.auth.uid || isAdmin());
        allow delete: if request.auth != null
                    && (eventAuthorId(database, eventId) == request.auth.uid || isAdmin());
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
                      && isValidComment(request.resource.data)
                      && request.resource.data.authorId == request.auth.uid
                      && request.resource.data.authorRole in ['general', 'member', 'honored', 'admin'];
        allow update, delete: if request.auth != null
                              && (resource.data.authorId == request.auth.uid || isAdmin());
      }

      match /likes/{likeId} {
        allow read: if true;
        allow create: if request.auth != null
                      && likeId == request.auth.uid
                      && isValidLike(request.resource.data, request.auth.uid);
        allow update, delete: if false;
      }
    }

    // 3. users
    match /users/{userId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && isValidUser(request.resource.data)
                    && request.resource.data.uid == userId
                    && request.resource.data.role == 'general';

      allow update: if request.auth != null
                    && (request.auth.uid == userId || isAdmin())
                    && isValidUserUpdate(resource.data, request.resource.data, isAdmin());

      allow delete: if request.auth != null
                    && (request.auth.uid == userId || isAdmin());

      // 부원 하트: users/{userId}/likes/{누른사람 uid}
      match /likes/{likeId} {
        allow read: if true;
        allow create: if request.auth != null
                      && likeId == request.auth.uid
                      && isValidLike(request.resource.data, request.auth.uid);
        allow update, delete: if false;
      }
    }

    match /faqs/{faqId} {
      allow read: if true;

      allow create: if request.auth != null
                    && isValidFaq(request.resource.data)
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.authorRole in ['general', 'member', 'honored', 'admin'];

      allow update, delete: if request.auth != null
                              && (resource.data.authorId == request.auth.uid || isAdmin());

      match /answers/{answerId} {
        allow read: if true;

        allow create: if request.auth != null
                      && request.resource.data.authorId == request.auth.uid
                      && request.resource.data.authorRole in ['general', 'member', 'honored', 'admin'];

        allow update, delete: if request.auth != null
                              && (resource.data.authorId == request.auth.uid || isAdmin());
      }

      match /likes/{likeId} {
        allow read: if true;
        allow create: if request.auth != null
                      && likeId == request.auth.uid
                      && isValidLike(request.resource.data, request.auth.uid);
        allow update, delete: if false;
      }
    }

    // 4. traffic
    match /traffic/{trafficId} {
      allow read: if request.auth != null
                  && isTrafficOwner(trafficId, request.auth.uid);

      allow create, update: if request.auth != null
                   && isTrafficOwner(trafficId, request.auth.uid)
                   && isValidTraffic(request.resource.data);

      allow delete: if request.auth != null
                    && isTrafficOwner(trafficId, request.auth.uid);
    }

    // 5. usernames
    match /usernames/{id} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && isValidUsername(request.resource.data);

      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == resource.data.uid
                    && isValidUsername(request.resource.data);

      allow delete: if request.auth != null
                    && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // 6. serverTimeCheck: 클라이언트 시계 오차 측정용 (본인만 읽고 씀)
    match /serverTimeCheck/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }

  function isValidNotice(data) {
    return data is map
           && data.title is string
           && data.title.size() <= 100
           && data.content is string
           && data.content.size() <= 10000
           && data.authorId is string
           && data.authorName is string
           && data.date is string
           && data.timestamp is int
           && (!('files' in data) || data.files is list)
           && (!('pinned' in data) || data.pinned is bool);
  }

  function isValidComment(data) {
    return data is map
           && data.content is string
           && data.content.size() <= 1000
           && data.authorId is string
           && data.authorName is string
           && data.date is string
           && data.timestamp is int;
  }

  function isValidFaq(data) {
    return data is map
           && data.title is string
           && data.title.size() <= 50
           && data.content is string
           && data.content.size() <= 3000
           && data.authorId is string
           && data.authorName is string
           && data.date is string
           && data.timestamp is int;
  }

  // 이벤트 목록 카드. deadline은 마감 시각(밀리초). timestamp는 서버시각과 20분 이내여야 함.
  function isValidEvent(data) {
    return data is map
           && data.title is string
           && data.title.size() <= 100
           && data.authorId is string
           && data.authorName is string
           && data.date is string
           && data.timestamp is int
           && data.deadline is int
           && isFreshTimestamp(data.timestamp)
           && (!('files' in data) || data.files is list);
  }

  function isValidEventContent(data) {
    return data is map
           && data.content is string
           && data.content.size() <= 10000
           && (!('files' in data) || data.files is list);
  }

  function isValidLike(data, uid) {
    return data is map
           && data.keys().hasOnly(['uid', 'timestamp'])
           && data.uid == uid
           && data.timestamp is int;
  }

  function isValidUser(data) {
    return data is map
           && data.uid is string
           && data.uid == request.auth.uid
           && data.id is string
           && (data.id.matches('^[A-Za-z0-9_]{4,20}$') || data.id == request.auth.uid)
           && data.batch is string
           && (data.batch == '' || data.batch.matches('^[0-9][0-9].$'))
           && data.name is string
           && data.name.size() >= 3
           && data.name.size() <= 10
           && data.role == 'general'
           && (!('email' in data))
           && (!('pwHash' in data))
           && (!('pw' in data));
  }

  function isValidUserUpdate(oldData, newData, isAdmin) {
    return newData is map
           && newData.uid == oldData.uid
           && (newData.uid == request.auth.uid || isAdmin)
           && newData.id == oldData.id
           && (newData.id.matches('^[A-Za-z0-9_]{4,20}$') || newData.id == newData.uid)
           && newData.batch == oldData.batch
           && (newData.batch == '' || newData.batch.matches('^[0-9][0-9].$'))
           && newData.name is string
           && newData.name.size() >= 3
           && newData.name.size() <= 10
           && (isAdmin || newData.role == oldData.role)
           && (isAdmin || newData.warnings == oldData.warnings)
           && (!('pwHash' in newData))
           && (!('pw' in newData));
  }

  function isValidTraffic(data) {
    return data is map
           && data.keys().hasOnly(['noticeCount', 'eventCount', 'uploadBytes', 'downloadBytes', 'commentCount', 'faqQuestionCount'])
           && (!('noticeCount' in data) || (data.noticeCount is int && data.noticeCount >= 0 && data.noticeCount <= 1000))
           && (!('eventCount' in data) || (data.eventCount is int && data.eventCount >= 0 && data.eventCount <= 1000))
           && (!('uploadBytes' in data) || (data.uploadBytes is int && data.uploadBytes >= 0 && data.uploadBytes <= 1073741824))
           && (!('downloadBytes' in data) || (data.downloadBytes is int && data.downloadBytes >= 0 && data.downloadBytes <= 1073741824))
           && (!('commentCount' in data) || (data.commentCount is int && data.commentCount >= 0 && data.commentCount <= 1000))
           && (!('faqQuestionCount' in data) || (data.faqQuestionCount is int && data.faqQuestionCount >= 0 && data.faqQuestionCount <= 1000));
  }

  function isValidUsername(data) {
    return data is map
           && data.uid is string
           && data.uid == request.auth.uid
           && data.batch is string
           && (data.batch == '' || data.batch.matches('^[0-9][0-9].$'))
           && data.name is string
           && data.name.size() >= 3
           && data.name.size() <= 10;
  }

  function isAdmin() {
    return request.auth != null && request.auth.token.admin == true;
  }

  function isTrafficOwner(trafficId, uid) {
    return trafficId.matches('^' + uid + '_.*');
  }

  // 클라이언트가 보낸 timestamp가 서버시각과 20분(1,200,000ms) 이내인지.
  // 컴퓨터 시계를 크게 조작한 상태의 쓰기를 서버가 거부한다.
  function isFreshTimestamp(ts) {
    return ts is int
           && request.time.toMillis() - ts <= 1200000
           && ts - request.time.toMillis() <= 1200000;
  }

  // 이벤트 본문 규칙에서 부모 이벤트 문서의 값을 읽어온다.
  function eventDeadline(database, eventId) {
    return get(/databases/$(database)/documents/events/$(eventId)).data.deadline;
  }

  function eventAuthorId(database, eventId) {
    return get(/databases/$(database)/documents/events/$(eventId)).data.authorId;
  }
}
